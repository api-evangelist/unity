{
  "summary": "Create a matchmaking ticket",
  "description": "Example showing how to enter a player into the matchmaking queue with skill-based matching attributes.",
  "request": {
    "method": "POST",
    "path": "/v3/projects/{projectId}/environments/{environmentId}/tickets",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "players": [
        {
          "id": "player_abc123",
          "attributes": {
            "skill": 1450,
            "gameMode": "ranked"
          }
        }
      ],
      "queueName": "ranked-1v1",
      "attributes": {
        "skill": 1450,
        "attributes": {
          "region": "us-east",
          "gameMode": "ranked"
        }
      }
    }
  },
  "response": {
    "status": 200,
    "body": {
      "id": "ticket_def456"
    }
  }
}
