{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Relationship",
  "title": "Relationship",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "FRIEND",
        "FRIEND_REQUEST",
        "BLOCK"
      ]
    },
    "member": {
      "$ref": "#/components/schemas/PlayerProfile"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    }
  }
}